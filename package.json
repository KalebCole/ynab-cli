{
  "name": "ynab-cli",
  "version": "1.0.0",
  "description": "A command-line interface for You Need a Budget (YNAB)",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "ynab": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "link": "npm run build && npm link",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ynab",
    "budget",
    "cli",
    "finance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ynab": "^2.10.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "conf": "^12.0.0",
    "keytar": "^7.9.0",
    "date-fns": "^3.0.0",
    "zod": "^3.22.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "vitest": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
